        <!-- Cinza tracejado: logs/metricas (fora do fluxo principal) -->
        <mxCell id="e_agw_mon" value="Logs L7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8A97A6;strokeWidth=1.8;dashed=1;dashPattern=6 4;fontColor=#5C6873;fontSize=10;endArrow=block;exitX=0;exitY=0.8;entryX=0.5;entryY=0;" edge="1" parent="1" source="ic_agw" target="ic_mon">
